# ============================================================
# integrated_qa_system — SAAS 部署环境变量清单
# 复制为 .env 并填入真实值，所有变量均支持回退到 config.ini
# ============================================================

# ---------- Secrets（生产环境必须设置，config.ini 不存明文）----------
MYSQL_PASSWORD=
REDIS_PASSWORD=
DEEPSEEK_API_KEY=
JWT_SECRET_KEY=

# ---------- 基础设施连接 ----------
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_DATABASE=subjects_kg
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=itcast
MILVUS_COLLECTION_NAME=edurag_final
MILVUS_TIMEOUT=10

# ---------- LLM ----------
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- Eval ----------
EVAL_LLM_MODEL=
EVAL_LLM_BASE_URL=
EVAL_EMBEDDING_MODEL=mxbai-embed-large
EVAL_EMBEDDING_BASE_URL=http://localhost:11434

# ---------- Auth ----------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_COST_FACTOR=12

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# ---------- /metrics 端点认证 ----------
METRICS_AUTH_USER=
METRICS_AUTH_PASSWORD=

# ---------- 安全响应头 ----------
SECURE_HEADERS_ENABLED=true

# ---------- 运行时调优 ----------
RETRIEVAL_K=5
RERANKER_SCORE_THRESHOLD=0.3
HEALTH_CHECK_TIMEOUT=5.0
MAX_CONCURRENT_LLM_CALLS=10
THREAD_POOL_WORKERS=20

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ---------- 业务 ----------
CUSTOMER_SERVICE_PHONE=12345678
