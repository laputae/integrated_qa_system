# ============================================================
# integrated_qa_system 配置文件模板
# 使用方式: 复制为 config.ini，通过环境变量注入敏感凭据
# ============================================================

# MySQL 配置
[mysql]
host = 127.0.0.1
user = root
# MYSQL_PASSWORD 环境变量
password =
database = subjects_kg

# Redis 配置
[redis]
host = 127.0.0.1
port = 6379
# REDIS_PASSWORD 环境变量
password =
db = 0


# Milvus 配置
[milvus]
host = 127.0.0.1
port = 19530
database_name = itcast
collection_name = edurag_final
timeout = 10

# LLM 配置
[llm]
model = deepseek-v4-pro
# DEEPSEEK_API_KEY 环境变量
dashscope_api_key =
# DEEPSEEK_BASE_URL 环境变量
dashscope_base_url = https://api.deepseek.com

# 嵌入模型配置
[embedding]
model = bge-m3
batch_size = 32
checkpoint_dir = checkpoints/embedding
cache_ttl = 86400

# 自适应Chunk配置
[chunking]
default_strategy = recursive
doc_type_strategies = {}
semantic_model_path =
semantic_device = cpu
semantic_fallback_strategy = recursive

# 检索参数配置
[retrieval]
parent_chunk_size = 1200
child_chunk_size = 300
chunk_overlap = 50
retrieval_k = 5
candidate_m = 2
max_workers = 3
reranker_score_threshold = 0.3

# LLM 重排序配置（关键查询精度提升）
[llm_reranker]
enabled = false
critical_min_length = 20
critical_strategies = 假设问题检索,回溯问题检索,子查询检索
listwise_k = 3

# 查询分类器配置
[classifier]
confidence_threshold = 0.8

# 策略选择配置
[strategy]
cache_ttl = 604800

# LLM 重试配置
[retry]
max_retries = 3
base_delay = 1.0
max_delay = 30.0

# 认证配置
[auth]
# JWT_SECRET_KEY 环境变量（必填）
jwt_secret_key =
access_token_expire_minutes = 30
refresh_token_expire_days = 7
bcrypt_cost_factor = 12

# 日志配置
[logger]
log_file = logs/app.log
log_level = INFO
log_format = json
log_max_bytes = 10485760
log_backup_count = 5

# 租户配置
[tenant]
default_tenant_name = default

# 健康检查配置
[health]
check_timeout = 5.0
cache_ttl = 30
recovery_interval = 60
circuit_breaker_threshold = 3
circuit_breaker_cooldown = 30

# 评估自动化管道配置
[eval]
eval_llm_model =
eval_llm_base_url =
eval_embedding_model = mxbai-embed-large
eval_embedding_base_url = http://localhost:11434
eval_interval_seconds = 21600
regression_faithfulness_threshold = 0.7
regression_consecutive_runs = 3
quality_warning_threshold = 0.7
quality_critical_threshold = 0.4
default_dataset_path = rag_qa/rag_assesment/rag_evaluate_data.json

# HallucinationGuard NLI 实时幻觉检测
[hallucination_guard]
enabled = false
model = MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7
entailment_threshold = 0.5
contradiction_threshold = 0.5

# 并发控制配置
[concurrency]
max_concurrent_llm_calls = 10
thread_pool_workers = 20

# /metrics 端点认证配置
[metrics]
metrics_auth_user =
metrics_auth_password =

# 安全响应头配置
[security_headers]
enabled = true

# 应用配置
[app]
valid_sources = ["ai", "java", "test", "ops", "bigdata"]
customer_service_phone = 12345678
cors_origins = http://localhost:3000,http://127.0.0.1:8000
